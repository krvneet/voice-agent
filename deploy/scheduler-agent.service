[Unit]
Description=Smart Scheduler — LiveKit agent worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# EDIT these two lines for your VM user + repo path:
User=YOUR_VM_USER
WorkingDirectory=/home/YOUR_VM_USER/livekitvoice-agent
ExecStart=/home/YOUR_VM_USER/livekitvoice-agent/venv/bin/python agent/agent.py start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
