# ── LiveKit Cloud (media transport) ─────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-secret

# ── LLM + STT: Groq (free tier) ─────────────────────────────────
GROQ_API_KEY=gsk_your_groq_key

# ── Fallback LLM: Google AI Studio (free tier, NOT Vertex) ───────
GEMINI_API_KEY=your_gemini_ai_studio_key

# groq | gemini  (which LLM the agent uses)
LLM_PROVIDER=groq

# ── Google Calendar (service account) ───────────────────────────
# Path to the calendar service-account JSON key (scheduler-cal SA).
GOOGLE_APPLICATION_CREDENTIALS=./gcal-sa.json
# The demo calendar ID shared with the service-account email.
GCAL_CALENDAR_ID=xxxxxxxx@group.calendar.google.com

# ── Agent behaviour ─────────────────────────────────────────────
AGENT_TIMEZONE=Asia/Kolkata
WORKING_HOURS_START=9
WORKING_HOURS_END=18
TTS_VOICE=af_heart
