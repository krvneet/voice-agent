[Unit]
Description=Smart Scheduler — web UI + token server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# EDIT these two lines for your VM user + repo path:
User=YOUR_VM_USER
WorkingDirectory=/home/YOUR_VM_USER/livekitvoice-agent
ExecStart=/home/YOUR_VM_USER/livekitvoice-agent/venv/bin/python -m uvicorn server:app --host 0.0.0.0 --port 8080 --app-dir web
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
